<%# Deux colonnes : infos du projet à gauche, discussions à droite %>
<div class="row">

  <%# Colonne de gauche : titre et description du projet %>
  <div class="col-md-8">
    <%# Titre du projet %>
    <h1><%= @project.title %></h1>
    <%# Description du projet (juste en dessous du titre) %>
    <p><%= @project.description %></p>
  </div>

  <%# Colonne de droite : la partie discussions %>
  <div class="col-md-4">
    <%# Titre de la section des discussions %>
    <h2>Discussions</h2>

    <%# Liste des discussions du projet (ou message s'il n'y en a aucune) %>
    <div class="mb-4">
      <% if @chats.present? %>
        <ul>
          <% @chats.each do |chat| %>
            <%# Un lien vers chaque discussion %>
            <%# si la discussion n'a pas de titre, on affiche "Untitled" %>
            <li><%= link_to (chat.title.presence || "Untitled"), chat_path(chat) %></li>
          <% end %>
        </ul>
      <% else %>
        Aucune discussion pour le moment.
      <% end %>
    </div>

    <%# Bouton pour créer une nouvelle discussion %>
    <%= button_to "Nouvelle discussion", project_chats_path(@project), class: "btn btn-primary" %>
  </div>

</div>

