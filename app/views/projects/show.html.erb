<%# ====== CSS de la page projet ====== %>
<style>
  /* --- En-tête du projet (colonne de gauche) --- */
  /* petit sur-titre "PROJET" en gris */
  .projet-surtitre {
    font-family: monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8A8880;
    margin-bottom: 8px;
  }
  /* le grand titre du projet, en serif */
  .projet-titre {
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: #2C2C2A;
    line-height: 1.1;
    margin: 0 0 10px;
  }
  /* la ligne d'infos (nombre de discussions, date) en gris */
  .projet-meta {
    font-family: monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8A8880;
    margin-bottom: 18px;
  }
  /* la description du projet */
  .projet-description {
    color: #4B4944;
    line-height: 1.7;
    max-width: 620px;
  }

  /* --- Panneau (colonne de droite) --- */
  /* la "carte" du panneau */
  .panneau {
    background: #FBF8F3;
    border: 1px solid rgba(44, 44, 42, 0.10);
    border-radius: 16px;
    padding: 22px;
  }
  /* le petit titre "Discussions" du panneau */
  .panneau-titre {
    font-family: monospace;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8A8880;
    margin: 0 0 16px;
  }
  /* le formulaire button_to ne prend pas de marge */
  .panneau form {
    margin: 0;
  }
  /* le bouton "+ Nouvelle discussion" en pleine largeur */
  .panneau .btn-primary {
    width: 100%;
    background: #2C2C2A;
    color: #fff;
    border: 1px solid #2C2C2A;
    border-radius: 999px;
    padding: 11px 16px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
  }
  .panneau .btn-primary:hover {
    background: #444;
    border-color: #444;
  }

  /* --- Section des visuels --- */
  /* l'en-tête de la section : titre à gauche, bouton à droite */
  .visuels-entete {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin: 48px 0 18px;
  }
  /* le titre "Vos visuels" en serif */
  .visuels-titre {
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #2C2C2A;
    margin: 0;
  }
  /* le bouton qui active le mode suppression des visuels */
  .btn-suppr-visuels {
    background: #fff;
    color: #2C2C2A;
    border: 1px solid #2C2C2A;
    border-radius: 999px;
    padding: 8px 18px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-suppr-visuels:hover {
    background: #F3EFE8;
  }

  /* les deux boutons d'une carte, alignés côte à côte */
  .card-actions {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    flex-wrap: wrap;
  }
  /* style commun des boutons de carte : même forme pill que partout ailleurs */
  .card-btn {
    display: inline-block;
    border-radius: 999px;
    padding: 9px 18px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid #2C2C2A;
    cursor: pointer;
    white-space: nowrap;
  }
  /* "Voir le visuel" : bouton principal (foncé plein) */
  .card-btn--primaire {
    background: #2C2C2A;
    color: #fff;
  }
  .card-btn--primaire:hover {
    background: #444;
    border-color: #444;
  }
  /* "Voir le chat" : bouton secondaire (clair avec contour) */
  .card-btn--secondaire {
    background: #fff;
    color: #2C2C2A;
  }
  .card-btn--secondaire:hover {
    background: #F3EFE8;
  }

  /* le formulaire du bouton supprimer (dans la carte) ne prend pas de marge */
  .card-trip form {
    margin: 0;
  }
  /* le bouton "Supprimer" d'un visuel est caché par défaut */
  .card-supprimer {
    display: none;
  }
  /* en mode suppression, on affiche les boutons "Supprimer" en rouge */
  .all-projects.mode-suppression .card-supprimer {
    display: inline-block;
    margin-top: 10px;
    background: #C1440E;
    color: #fff;
    border: none;
    padding: 6px 16px;
    border-radius: 999px;
    font-size: 0.82rem;
    cursor: pointer;
  }
</style>

<%# ====== Contenu de la page ====== %>
<div class="row">

  <%# Colonne de gauche : informations du projet %>
  <div class="col-md-8">
    <%# petit sur-titre %>
    <p class="projet-surtitre">Projet</p>
    <%# titre du projet %>
    <h1 class="projet-titre"><%= @project.title %></h1>
    <%# nombre de discussions + date de création %>
    <p class="projet-meta"><%= pluralize(@chats.size, "discussion") %> · créé le <%= @project.created_at.strftime("%d/%m/%Y") %></p>
    <%# description du projet %>
    <p class="projet-description"><%= @project.description %></p>
  </div>

  <%# Colonne de droite : panneau pour créer une discussion %>
  <div class="col-md-4">
    <div class="panneau">
      <%# titre du panneau %>
      <h2 class="panneau-titre">Discussions</h2>
      <%# bouton pour créer une nouvelle discussion %>
      <%= button_to "+ Nouvelle discussion", project_chats_path(@project), class: "btn btn-primary" %>
    </div>
  </div>

</div>

<%# ====== Section des visuels ====== %>
<div class="visuels-entete">
  <%# titre de la section %>
  <h2 class="visuels-titre">Vos visuels</h2>
  <% if @chats.present? %>
    <%# bouton qui active/désactive le mode suppression des visuels %>
    <button type="button" id="btn-suppr-visuels" class="btn-suppr-visuels" onclick="basculerSuppressionVisuels(this)">Supprimer un visuel</button>
  <% end %>
</div>

<%# CSS pour que les visuels ne soient pas recadrés/zoomés et aient un fond propre %>
<style>
  /* le fond coloré : même taille que l'ancienne image, avec un peu d'air autour */
  .visuels-grille .card-trip > .visuel-fond {
    height: 190px;
    width: 100%;
    /* on centre l'image au milieu du fond coloré */
    display: flex;
    align-items: center;
    justify-content: center;
    /* l'espace autour de l'image fait apparaître la couleur comme un cadre */
    padding: 14px;
    /* coins du haut arrondis pour épouser le cadre de la carte */
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
  }
  /* l'image elle-même : entière (pas zoomée) et arrondie sur ses 4 coins */
  .visuels-grille .card-trip > .visuel-fond img {
    /* on limite l'image à la taille du fond sans la déformer */
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    /* contain = on voit toute l'image sans la couper ni la zoomer */
    object-fit: contain;
    /* coins arrondis sur l'image seule */
    border-radius: 14px;
  }
  /* on fait varier la couleur du fond d'une card à l'autre (palette fun) */
  /* 1re, 7e, 13e... cards : corail */
  .visuels-grille .card-trip:nth-child(6n+1) > .visuel-fond { background: #FFB5A7; }
  /* 2e, 8e... cards : jaune doux */
  .visuels-grille .card-trip:nth-child(6n+2) > .visuel-fond { background: #FCD5A5; }
  /* 3e, 9e... cards : vert menthe */
  .visuels-grille .card-trip:nth-child(6n+3) > .visuel-fond { background: #B5EAD7; }
  /* 4e, 10e... cards : bleu ciel */
  .visuels-grille .card-trip:nth-child(6n+4) > .visuel-fond { background: #A0D8EF; }
  /* 5e, 11e... cards : lavande */
  .visuels-grille .card-trip:nth-child(6n+5) > .visuel-fond { background: #CDB4DB; }
  /* 6e, 12e... cards : rose poudré */
  .visuels-grille .card-trip:nth-child(6n+6) > .visuel-fond { background: #FFC8DD; }
</style>

<div class="all-projects visuels-grille">
  <%# Cas vide : aucune discussion, donc aucun visuel %>
  <% if @chats.empty? %>
    <div class="card-trip">
      <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
      <div class="card-trip-infos">
        <div>
          <h2>Aucun visuel</h2>
          <p>Crée ta première discussion pour générer un visuel.</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Une carte (visuel) par discussion %>
  <% @chats.each do |chat| %>
    <div class="card-trip">
      <%# ce div porte la couleur de fond ; l'image arrondie est posée dessus %>
      <div class="visuel-fond">
        <% if chat.furniture&.image&.attached? %>
          <%# le visuel généré pour cette discussion %>
          <%= cl_image_tag chat.furniture.image.key %>
        <% else %>
          <%# pas encore de visuel généré : on garde une image par défaut %>
          <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
        <% end %>
      </div>

      <div class="card-trip-infos">
        <div>
          <% if chat.furniture.present? %>
            <%# titre du meuble proposé %>
            <h2><%= chat.furniture.title %></h2>
          <% else %>
            <%# pas encore de meuble : on affiche le titre de la discussion %>
            <h2><%= chat.title.presence || "Discussion" %></h2>
          <% end %>
          <%# lien vers la discussion, présent sur toutes les cartes %>
          <div class="card-actions">
            <%# bouton secondaire vers la discussion %>
            <%= link_to "Voir le chat", chat_path(chat), class: "card-btn card-btn--secondaire" %>
            <%# bouton principal vers la page visuel %>
            <%= link_to "Voir le visuel", visuel_chat_path(chat), class: "card-btn card-btn--primaire" %>
          </div>
          <%# bouton pour supprimer ce visuel (caché sauf en mode suppression) %>
          <%= button_to "Supprimer", chat_path(chat), method: :delete, form: { data: { turbo: false }, onsubmit: "return confirm('Supprimer ce visuel ?')" }, class: "btn card-supprimer" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# ====== JavaScript du mode suppression des visuels ====== %>
<script>
  // Fonction appelée au clic sur "Supprimer un visuel" / "Terminé"
  function basculerSuppressionVisuels(bouton) {
    // on récupère la liste des visuels
    const liste = document.querySelector('.all-projects');
    // on ajoute ou enlève la classe "mode-suppression" ; toggle renvoie true si elle est ajoutée
    const modeActif = liste.classList.toggle('mode-suppression');
    // si le mode est actif on écrit "Terminé"
    if (modeActif) {
      bouton.textContent = "Terminé";
    // sinon on remet le texte d'origine et on nettoie l'adresse
    } else {
      bouton.textContent = "Supprimer un visuel";
      history.replaceState(null, "", window.location.pathname);
    }
  }

  // Au chargement : si on revient d'une suppression, on garde le mode actif
  if (window.location.search.includes("suppression=1")) {
    // on récupère la liste des visuels
    const liste = document.querySelector(".all-projects");
    // on récupère le bouton "Supprimer un visuel"
    const bouton = document.querySelector("#btn-suppr-visuels");
    // si les deux existent, on réactive le mode et on affiche "Terminé"
    if (liste && bouton) {
      liste.classList.add("mode-suppression");
      bouton.textContent = "Terminé";
    }
  }
</script>
