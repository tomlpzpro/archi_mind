<%# ====== CSS de la page projet ====== %>
<style>
  /* --- En-tête du projet (colonne de gauche) --- */
  /* petit sur-titre "PROJET" en gris */
  .projet-surtitre {
    font-family: monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8A8880;
    margin-bottom: 8px;
  }
  /* le grand titre du projet, en serif */
  .projet-titre {
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: #2C2C2A;
    line-height: 1.1;
    margin: 0 0 10px;
  }
  /* la ligne d'infos (nombre de discussions, date) en gris */
  .projet-meta {
    font-family: monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8A8880;
    margin-bottom: 18px;
  }
  /* la description du projet */
  .projet-description {
    color: #4B4944;
    line-height: 1.7;
    max-width: 620px;
  }

  /* --- Panneau des discussions (colonne de droite) --- */
  /* la "carte" qui contient toute la partie discussions */
  .panneau {
    background: #FBF8F3;
    border: 1px solid rgba(44, 44, 42, 0.10);
    border-radius: 16px;
    padding: 22px;
  }
  /* le petit titre "Discussions" du panneau */
  .panneau-titre {
    font-family: monospace;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8A8880;
    margin: 0 0 16px;
  }

  /* la liste des discussions : pas de puces, en colonne propre */
  .liste-discussions {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
  }
  /* chaque discussion : lien à gauche, bouton supprimer à droite */
  .liste-discussions li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 11px 14px;
    background: #fff;
    border: 1px solid rgba(44, 44, 42, 0.08);
    border-radius: 10px;
    margin-bottom: 8px;
  }
  /* le lien de la discussion */
  .liste-discussions li a {
    color: #2C2C2A;
    text-decoration: none;
    font-weight: 500;
  }
  .liste-discussions li a:hover {
    color: #C1440E;
  }
  /* button_to crée un <form> : on enlève sa marge pour bien aligner le bouton */
  .liste-discussions li form {
    margin: 0;
  }

  /* les deux boutons d'action empilés l'un sous l'autre (la colonne est étroite) */
  .discussions-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  /* le formulaire button_to prend toute la largeur du panneau */
  .discussions-actions form {
    margin: 0;
    width: 100%;
  }
  /* style commun aux deux boutons d'action : même forme, pleine largeur (DA cohérente) */
  .discussions-actions .btn {
    width: 100%;
    border-radius: 999px;
    padding: 11px 16px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid #2C2C2A;
    white-space: nowrap;
  }
  /* "Nouvelle discussion" : bouton plein foncé (action principale) */
  .discussions-actions .btn-primary {
    background: #2C2C2A;
    color: #fff;
  }
  .discussions-actions .btn-primary:hover {
    background: #444;
    border-color: #444;
  }
  /* "Supprimer une discussion" : même forme mais claire avec contour (action secondaire) */
  .discussions-actions .btn-pill {
    background: #fff;
    color: #2C2C2A;
  }
  .discussions-actions .btn-pill:hover {
    background: #F3EFE8;
  }

  /* le bouton "Supprimer" d'une discussion est caché par défaut */
  .discussion-supprimer {
    display: none;
  }
  /* en mode suppression, on affiche les boutons "Supprimer" en rouge */
  .liste-discussions.mode-suppression .discussion-supprimer {
    display: inline-block;
    background: #C1440E;
    color: #fff;
    border: none;
    padding: 3px 12px;
    font-size: 0.78rem;
    border-radius: 6px;
    cursor: pointer;
  }

  /* --- Section des visuels --- */
  /* le titre "Vos visuels" : vrai titre en serif */
  .visuels-titre {
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #2C2C2A;
    margin: 48px 0 18px;
  }
  /* la grille des visuels : s'adapte à la largeur de l'écran */
  .visuels-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }
  /* un visuel : un rectangle arrondi avec un dégradé chaud */
  .visuel {
    aspect-ratio: 4 / 3;
    border-radius: 14px;
    border: 1px solid rgba(44, 44, 42, 0.08);
  }
  /* trois dégradés différents pour varier */
  .visuel--1 { background: linear-gradient(135deg, #E9E0D2, #CDB99E); }
  .visuel--2 { background: linear-gradient(135deg, #E4D3C0, #B79B7E); }
  .visuel--3 { background: linear-gradient(135deg, #D9CDB6, #A8946F); }
</style>

<%# ====== Contenu de la page ====== %>
<div class="row">

  <%# Colonne de gauche : informations du projet %>
  <div class="col-md-8">
    <%# petit sur-titre %>
    <p class="projet-surtitre">Projet</p>
    <%# titre du projet %>
    <h1 class="projet-titre"><%= @project.title %></h1>
    <%# nombre de discussions + date de création %>
    <p class="projet-meta"><%= pluralize(@chats.size, "discussion") %> · créé le <%= @project.created_at.strftime("%d/%m/%Y") %></p>
    <%# description du projet %>
    <p class="projet-description"><%= @project.description %></p>
  </div>

  <%# Colonne de droite : panneau des discussions %>
  <div class="col-md-4">
    <div class="panneau">
      <%# titre du panneau %>
      <h2 class="panneau-titre">Discussions</h2>

      <%# liste des discussions (ou message s'il n'y en a aucune) %>
      <% if @chats.present? %>
        <ul class="liste-discussions">
          <% @chats.each do |chat| %>
            <li>
              <%# lien vers la discussion (si pas de titre, on affiche "Untitled") %>
              <%= link_to (chat.title.presence || "Untitled"), chat_path(chat) %>
              <%# bouton "Supprimer" cette discussion (caché sauf en mode suppression) %>
              <%= button_to "Supprimer", chat_path(chat), method: :delete, form: { data: { turbo: false }, onsubmit: "return confirm('Supprimer cette discussion ?')" }, class: "btn discussion-supprimer" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p style="color:#8A8880;">Aucune discussion pour le moment.</p>
      <% end %>

      <%# les deux boutons d'action, sur une même ligne %>
      <div class="discussions-actions">
        <%# bouton pour créer une nouvelle discussion %>
        <%= button_to "+ Nouvelle discussion", project_chats_path(@project), class: "btn btn-primary" %>
        <% if @chats.present? %>
          <%# bouton qui active/désactive le mode suppression %>
          <button type="button" id="btn-suppr-discussions" class="btn btn-pill" onclick="basculerSuppressionDiscussions(this)">Supprimer une discussion</button>
        <% end %>
      </div>
    </div>
  </div>

</div>

<%# Section des visuels du projet %>
<p class="visuels-titre">Vos visuels</p>
<div class="visuels-grille">
  <%# trois visuels d'exemple (dégradés) en attendant de vrais visuels %>
  <div class="visuel visuel--1"></div>
  <div class="visuel visuel--2"></div>
  <div class="visuel visuel--3"></div>
</div>

<%# ====== JavaScript du mode suppression des discussions ====== %>
<script>
  // Fonction appelée au clic sur "Supprimer une discussion" / "Terminé"
  function basculerSuppressionDiscussions(bouton) {
    // on récupère la liste des discussions
    const liste = document.querySelector('.liste-discussions');
    // on ajoute ou enlève la classe "mode-suppression" ; toggle renvoie true si elle est ajoutée
    const modeActif = liste.classList.toggle('mode-suppression');
    // si le mode est actif on écrit "Terminé"
    if (modeActif) {
      bouton.textContent = "Terminé";
    // sinon on remet le texte d'origine et on nettoie l'adresse
    } else {
      bouton.textContent = "Supprimer une discussion";
      history.replaceState(null, "", window.location.pathname);
    }
  }

  // Au chargement : si on revient d'une suppression, on garde le mode actif
  if (window.location.search.includes("suppression=1")) {
    // on récupère la liste des discussions
    const liste = document.querySelector(".liste-discussions");
    // on récupère le bouton "Supprimer une discussion"
    const bouton = document.querySelector("#btn-suppr-discussions");
    // si les deux existent, on réactive le mode et on affiche "Terminé"
    if (liste && bouton) {
      liste.classList.add("mode-suppression");
      bouton.textContent = "Terminé";
    }
  }
</script>
