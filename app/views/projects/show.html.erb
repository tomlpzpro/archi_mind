<%# ====== Contenu de la page ====== %>
<div class="row">

  <%# Colonne de gauche : informations du projet %>
  <div class="col-md-8">
    <%# petit sur-titre %>
    <p class="projet-surtitre">Projet</p>
    <%# titre du projet %>
    <h1 class="projet-titre"><%= @project.title %></h1>
    <%# nombre de discussions + date de création %>
    <p class="projet-meta"><%= pluralize(@chats.size, "discussion") %> · créé le <%= @project.created_at.strftime("%d/%m/%Y") %></p>
    <%# description du projet %>
    <p class="projet-description"><%= @project.description %></p>
  </div>

  <%# Colonne de droite : panneau pour créer une discussion %>
  <div class="col-md-4">
    <div class="panneau">
      <%# titre du panneau %>
      <h2 class="panneau-titre">Discussions</h2>
      <%# bouton pour créer une nouvelle discussion %>
      <%= button_to "+ Nouvelle discussion", project_chats_path(@project), class: "btn btn-primary" %>
    </div>
  </div>

</div>

<%# ====== Section des visuels ====== %>
<div class="visuels-entete">
  <%# titre de la section %>
  <h2 class="visuels-titre">Vos visuels</h2>
</div>

<div class="all-projects visuels-grille">
  <%# Cas vide : aucune discussion, donc aucun visuel %>
  <% if @chats.empty? %>
    <div class="card-trip">
      <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
      <div class="card-trip-infos">
        <div>
          <h2>Aucun visuel</h2>
          <p>Crée ta première discussion pour générer un visuel.</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Une carte (visuel) par discussion %>
  <% @chats.each do |chat| %>
    <div class="card-trip">
      <%# ce div porte la couleur de fond ; l'image arrondie est posée dessus %>
      <div class="visuel-fond">
        <% if chat.furniture&.image&.attached? %>
          <%# le visuel généré pour cette discussion %>
          <%= cl_image_tag chat.furniture.image.key %>
        <% else %>
          <%# pas encore de visuel généré : on garde une image par défaut %>
          <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
        <% end %>
      </div>

      <div class="card-trip-infos">
        <% if chat.furniture.present? %>
          <%# titre du meuble proposé %>
          <h2><%= chat.furniture.title %></h2>
        <% else %>
          <%# pas encore de meuble : on affiche le titre de la discussion %>
          <h2><%= chat.title.presence || "Discussion" %></h2>
        <% end %>
        <%# les boutons, toujours collés en bas de la carte %>
        <div class="card-actions">
          <%# bouton secondaire vers la discussion %>
          <%= link_to "Voir le chat", chat_path(chat), class: "card-btn card-btn--secondaire" %>
          <%# bouton principal vers la page visuel %>
          <%= link_to "Voir le visuel", visuel_chat_path(chat), class: "card-btn card-btn--primaire" %>
          <%# bouton pour supprimer ce visuel %>
          <%# turbo: false force un rechargement complet après la suppression %>
          <%# onsubmit affiche une confirmation avant de supprimer %>
          <%= button_to "Supprimer", chat_path(chat), method: :delete, form: { data: { turbo: false }, onsubmit: "return confirm('Supprimer ce visuel ?')" }, class: "card-btn card-btn--supprimer" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
