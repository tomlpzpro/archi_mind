<%= link_to "← #{@chat.project.title}", project_path(@chat.project) %>

<%# Petit CSS pour que le titre éditable ait l'air d'un vrai titre %>
<style>
  /* le formulaire du titre : champ à gauche, bouton à droite */
  .titre-form {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 8px 0 28px;
  }
  /* le champ ressemble à un grand titre, sans bordure visible */
  .titre-champ {
    flex: 1;
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: #2C2C2A;
    background: transparent;
    border: none;
    border-bottom: 2px solid #E5E1D8;
    padding: 6px 2px;
    outline: none;
  }
  /* le texte d'invitation (placeholder) en plus clair et en italique */
  .titre-champ::placeholder {
    color: #B8B5AE;
    font-weight: 400;
    font-style: italic;
  }
  /* quand on clique dans le champ, le trait du bas devient foncé */
  .titre-champ:focus {
    border-bottom-color: #2C2C2A;
  }
  /* le bouton "Enregistrer" : petite pastille foncée */
  .titre-bouton {
    flex: 0 0 auto;
    background: #2C2C2A;
    color: #fff;
    border: none;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 0.85rem;
    cursor: pointer;
  }
  /* au survol du bouton, on éclaircit un peu */
  .titre-bouton:hover {
    background: #444;
  }
</style>

<%# Formulaire pour modifier le titre de la discussion %>
<%= form_with model: @chat, class: "titre-form" do |f| %>
  <%# Champ du titre : vide s'il n'y a pas (encore) de titre, ce qui affiche le texte d'invitation %>
  <%= f.text_field :title,
        value: (@chat.title == "Untitled" ? "" : @chat.title),
        placeholder: "Saisissez le titre de cette discussion",
        class: "titre-champ" %>
  <%# Bouton pour enregistrer le titre %>
  <%= f.submit "Enregistrer le titre", class: "titre-bouton" %>
<% end %>

<% @chat.messages.each do |message| %>
  <p>
    <strong>
      <% if message.role == "user" %>
        <%# message écrit par l'utilisateur connecté %>
        Vous
      <% else %>
        <%# message écrit par l'assistant (l'IA) %>
        Archi Mind
      <% end %>
    </strong>
    <%= message.content %>
  </p>
<% end %>

<div id="new_message_container">
    <%= simple_form_for [@chat, @message] do |f| %>
    <%= f.input :content, label: "Posez votre question", required: true, placeholder: "Décrivez ce que vous souhaitez aménager…" %>
    <%= f.button :submit, 'Envoyer', class: 'btn btn-primary' %>
  <% end %>
</div>
