<%= link_to "← #{@chat.project.title}", project_path(@chat.project) %>

<h1 class="titre-champ">
  <%= @chat.title %>
</h1>

<%# Bulle d'accueil d'Archi Mind (toujours à gauche) %>
<div class="message message--archi">
  <div class="bulle">
    <span class="bulle-auteur">Archi Mind</span>
    Bonjour, je suis Archi Mind, votre assistant pour trouver des idées de meubles adaptées à vos projets. Comment puis-je vous aider aujourd'hui ?
  </div>
</div>

<%# Tous les messages de la discussion %>
<% @chat.messages.each do |message| %>
<% if @chat.messages.last == message && message.role == "assistant" && @chat.furniture&.image&.attached? %>
  <%# le visuel généré, affiché dans une bulle d'Archi Mind, en plus petit %>
  <div class="message message--archi">
    <div class="bulle">
      <span class="bulle-auteur">Archi Mind</span>
      <%= cl_image_tag @chat.furniture.image.key, class: "visuel-image" %>
    </div>
  </div>
<% end %>
  <% if message.role == "user" %>
    <%# message de l'utilisateur : à droite, bulle foncée %>
    <div class="message message--vous">
      <div class="bulle">
        <span class="bulle-auteur">Vous</span>
        <%= message.content %>
      </div>
    </div>
  <% else %>
    <%# message d'Archi Mind : à gauche, bulle claire %>
    <div class="message message--archi">
      <div class="bulle">
        <span class="bulle-auteur">Archi Mind</span>
        <%# on convertit le Markdown (ex: **gras**) en vrai texte mis en forme %>
        <%= markdown(message.content) %>
      </div>
    </div>
    <%# si c'est le dernier message d'Archi Mind, qu'un meuble a été décrit et que l'image n'est pas encore générée, on propose deux boutons %>
    <% if @chat.messages.last == message && @chat.furniture.present? && !@chat.furniture.image.attached? %>
      <%# data-actions-visuel sert à retrouver ce bloc pour le cacher avec le bouton "continuer" %>
      <div class="actions-visuel" data-actions-visuel>
        <%# bouton qui génère le visuel : envoie un POST vers l'action generer_visuel %>
        <%= button_to "Générer le visuel", generer_visuel_chat_path(@chat), method: :post, class: "bouton-visuel" %>
        <%# bouton qui cache simplement ces boutons pour continuer à écrire dans la barre du bas %>
        <button type="button" class="bouton-continuer" onclick="this.closest('[data-actions-visuel]').remove()">Continuer à discuter avec Archi Mind</button>
      </div>
    <% end %>
  <% end %>
<% end %>

<div id="new_message_container">
  <%# form_with envoie le message ; classe "composer" pour la barre arrondie %>
  <%= simple_form_for [@chat, @message], html: { class: "composer" } do |f| %>
    <%# input_field = juste le champ (sans label ni encadré simple_form) %>
    <%= f.input_field :content,
          required: true,
          placeholder: "Décrivez ce que vous souhaitez aménager…",
          class: "composer-champ" %>
    <%# bouton pour envoyer le message %>
    <%= f.button :submit, "Envoyer", class: "composer-bouton" %>
  <% end %>
</div>
