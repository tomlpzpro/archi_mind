<%# ====== CSS de la page proposition (version client) ====== %>
<style>
  /* conteneur centré de la page */
  .proposition {
    max-width: 760px;
    margin: 0 auto;
    padding: 30px 20px 60px;
    text-align: center;
  }
  /* la marque "Archi Mind" en haut */
  .proposition-marque {
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 1.4rem;
    color: #2C2C2A;
    margin-bottom: 40px;
  }
  /* petit sur-titre en gris */
  .proposition-surtitre {
    font-family: monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8A8880;
    margin-bottom: 10px;
  }
  /* le nom du projet, en grand titre serif */
  .proposition-titre {
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #2C2C2A;
    margin: 0 0 28px;
  }
  /* le visuel en grand, coins arrondis */
  .proposition-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 18px;
    border: 1px solid rgba(44, 44, 42, 0.10);
  }
  /* la description sous le visuel */
  .proposition-description {
    color: #4B4944;
    line-height: 1.7;
    max-width: 560px;
    margin: 28px auto 0;
  }
  /* le pied de page avec le slogan et le lien Archi Mind */
  .proposition-pied {
    margin-top: 50px;
    padding-top: 24px;
    border-top: 1px solid rgba(44, 44, 42, 0.10);
  }
  /* le slogan en gris */
  .proposition-slogan {
    color: #8A8880;
    margin-bottom: 8px;
  }
  /* le lien vers le site Archi Mind, en terracotta */
  .proposition-lien {
    color: #C1440E;
    font-weight: 600;
    text-decoration: none;
  }
  .proposition-lien:hover {
    text-decoration: underline;
  }
</style>

<%# ====== Contenu de la page ====== %>
<div class="proposition">

  <%# la marque tout en haut %>
  <p class="proposition-marque">Archi Mind.</p>

  <%# petit sur-titre %>
  <p class="proposition-surtitre">Proposition d'aménagement</p>
  <%# nom du projet %>
  <h1 class="proposition-titre"><%= @chat.project.title %></h1>

  <%# le visuel en grand (image d'exemple pour l'instant) %>
  <img class="proposition-image" src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" alt="Proposition d'aménagement">

  <%# la description : celle du meuble si elle existe %>
  <p class="proposition-description">
    <% if @chat.furniture.present? %>
      <%= @chat.furniture.description %>
    <% else %>
      Voici la proposition d'aménagement imaginée pour votre projet.
    <% end %>
  </p>

  <%# pied de page : slogan + lien vers le site %>
  <div class="proposition-pied">
    <p class="proposition-slogan">Donnez vie à vos idées d'intérieur.</p>
    <%= link_to "Archi Mind", root_path, class: "proposition-lien" %>
  </div>

</div>
