<%# ====== Contenu de la page ====== %>
<div class="proposition">

  <%# la marque tout en haut %>
  <p class="proposition-marque">Archi Mind.</p>

  <%# petit sur-titre %>
  <p class="proposition-surtitre">Proposition d'aménagement</p>
  <%# nom du projet %>
  <h1 class="proposition-titre"><%= @chat.project.title %></h1>

  <%# le visuel en grand (image d'exemple pour l'instant) %>
  <img class="proposition-image" src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" alt="Proposition d'aménagement">

  <%# la description : celle du meuble si elle existe %>
  <p class="proposition-description">
    <% if @chat.furniture.present? %>
      <%= @chat.furniture.description %>
    <% else %>
      Voici la proposition d'aménagement imaginée pour votre projet.
    <% end %>
  </p>

  <%# pied de page : slogan + lien vers le site %>
  <div class="proposition-pied">
    <p class="proposition-slogan">Donnez vie à vos idées d'intérieur.</p>
    <%= link_to "Archi Mind", root_path, class: "proposition-lien" %>
  </div>

</div>
