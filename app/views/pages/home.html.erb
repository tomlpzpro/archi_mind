<div class="home">

  <section class="home-hero">
    <p class="label-mono">Archi Mind</p>
    <h1>Sur quel projet voulez-vous <em>travailler</em> aujourd'hui ?</h1>
    <p class="home-hero__lead">
      Donnez vie à vos idées d'intérieur, explorez des concepts et
      transformez vos projets en images grâce à l'IA.
    </p>
    <%= link_to new_project_path, class: "btn btn-primary home-hero__cta" do %>
      <span class="home-hero__plus">+</span> Créer un nouveau projet
    <% end %>
  </section>

  <% if user_signed_in? %>
    <section class="home-projects">
      <div class="section-head">
        <h3 class="label-mono">Vos projets</h3>

        <% if @projects.any? %>
          <%# Bouton qui active/désactive le mode suppression %>
          <%# Au clic, il ajoute ou enlève la classe "mode-suppression" sur la liste des projets %>
          <button type="button"
                  class="btn btn-pill"
                  onclick="basculerModeSuppression(this)">
            Supprimer un projet
          </button>
        <% end %>
      </div>

      <% if @projects.any? %>
        <div class="all-projects">
          <% @projects.each do |project| %>
            <article class="card-trip">
              <%# on cherche le premier meuble du projet dont l'image (le visuel) est générée %>
              <% visuel = project.furnitures.find { |furniture| furniture.image.attached? } %>
              <%# si un visuel existe, on affiche sa photo ; sinon on garde le rectangle de couleur %>
              <% if visuel %>
                <%= cl_image_tag visuel.image.key %>
              <% else %>
                <div class="card-trip__thumb"></div>
              <% end %>
              <div class="card-trip-infos">
                <div>
                  <h2><%= project.title %></h2>
                  <p>
                    <%= pluralize(project.furnitures.size, "pièce") %>
                    · maj <%= project.updated_at.strftime("%d/%m") %>
                  </p>
                </div>
                <%= link_to "Ouvrir", project_path(project), class: "btn btn-pill card-trip__open" %>
                <%# Bouton "Supprimer" : caché par défaut, visible en mode suppression (voir le CSS) %>
                <%# turbo: false force un rechargement complet de la page après la suppression %>
                <%# onsubmit affiche une demande de confirmation avant de supprimer %>
                <%= button_to "Supprimer", project_path(project), method: :delete, form: { data: { turbo: false }, onsubmit: "return confirm('Supprimer ce projet ?')" }, class: "btn card-trip__delete" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p>Vous n'avez pas encore de projet.</p>
          <%= link_to "Créer votre premier projet", new_project_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>
  <% end %>

</div>

<script>
  // Fonction appelée quand on clique sur le bouton "Supprimer un projet" / "Terminé"
  function basculerModeSuppression(bouton) {
    // on récupère la liste des projets
    const liste = document.querySelector('.all-projects');
    // on ajoute ou enlève la classe "mode-suppression" ; toggle renvoie true si elle est ajoutée
    const modeActif = liste.classList.toggle('mode-suppression');
    // si le mode est actif on écrit "Terminé"
    if (modeActif) {
      bouton.textContent = "Terminé";
    // sinon on remet le texte d'origine et on nettoie l'adresse
    } else {
      bouton.textContent = "Supprimer un projet";
      // on enlève "?suppression=1" de l'adresse pour ne pas réactiver le mode si on rafraîchit
      history.replaceState(null, "", window.location.pathname);
    }
  }

  // Au chargement de la page : si on revient d'une suppression, on garde le mode actif
  if (window.location.search.includes("suppression=1")) {
    // on récupère la liste des projets
    const listeProjets = document.querySelector(".all-projects");
    // on récupère le bouton "Supprimer un projet"
    const boutonSuppr = document.querySelector(".section-head button");
    // si les deux existent, on réactive le mode et on affiche "Terminé"
    if (listeProjets && boutonSuppr) {
      listeProjets.classList.add("mode-suppression");
      boutonSuppr.textContent = "Terminé";
    }
  }
</script>
