<div class="home">

  <section class="home-hero">
    <%# conteneur qui limite la largeur du texte du hero %>
    <div class="home-hero__inner">
      <%# petit badge d'accroche en haut %>
      <span class="home-hero__badge">✦ Design d'intérieur augmenté par l'IA</span>
      <%# grand titre principal %>
      <h1>Sur quel projet voulez-vous <em>travailler</em> aujourd'hui ?</h1>
      <%# paragraphe d'introduction %>
      <p class="home-hero__lead">
        Donnez vie à vos idées d'intérieur, explorez des concepts et
        transformez vos projets en images grâce à l'IA.
      </p>
      <%# bouton d'appel à l'action vers la création de projet %>
      <%= link_to new_project_path, class: "btn btn-primary home-hero__cta" do %>
        <span class="home-hero__plus">+</span> Créer un nouveau projet
      <% end %>
    </div>
  </section>

  <% if user_signed_in? %>
    <section class="home-projects">
      <div class="section-head">
        <%# titre de la section projets %>
        <h3 class="label-mono">Vos projets</h3>
      </div>

      <% if @projects.any? %>
        <div class="all-projects">
          <% @projects.each do |project| %>
            <article class="card-trip">
              <%# on cherche le premier meuble du projet dont l'image (le visuel) est générée %>
              <% visuel = project.furnitures.find { |furniture| furniture.image.attached? } %>
              <%# si un visuel existe, on affiche sa photo ; sinon on garde le rectangle de couleur %>
              <% if visuel %>
                <%= cl_image_tag visuel.image.key %>
              <% else %>
                <div class="card-trip__thumb"></div>
              <% end %>
              <div class="card-trip-infos">
                <div>
                  <%# titre du projet %>
                  <h2><%= project.title %></h2>
                  <%# nombre de pièces + date de mise à jour %>
                  <p>
                    <%= pluralize(project.furnitures.size, "pièce") %>
                    · maj <%= project.updated_at.strftime("%d/%m") %>
                  </p>
                </div>
                <%# groupe des deux boutons d'action, alignés à droite %>
                <div class="card-trip__actions">
                  <%# bouton pour ouvrir le projet %>
                  <%= link_to "Ouvrir", project_path(project), class: "btn btn-pill card-trip__open" %>
                  <%# bouton pour supprimer le projet (toujours visible) %>
                  <%# turbo: false force un rechargement complet de la page après la suppression %>
                  <%# onsubmit affiche une demande de confirmation avant de supprimer %>
                  <%= button_to "Supprimer", project_path(project), method: :delete, form: { data: { turbo: false }, onsubmit: "return confirm('Supprimer ce projet ?')" }, class: "btn card-trip__delete" %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p>Vous n'avez pas encore de projet.</p>
          <%= link_to "Créer votre premier projet", new_project_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </section>
  <% end %>

</div>
